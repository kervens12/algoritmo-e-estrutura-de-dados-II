 #include <stdio.h>
 #include <stdlib.h>
 
 int main(){
 	int linhas, colunas;
 	int i,j;
 	printf("Digite o numero de Linhas: ");
  		scanf("%d",&linhas);
  	printf("Digite o numero de Colunas: ");
  		scanf("%d",&colunas);
  	int **matriz; 									//ponteiro para matriz
	matriz = (int **) malloc(linhas *sizeof(int*)); //alocar memoria para as linhas 
	for(i =0; i < linhas; i++){
		matriz[i] = ( int *) malloc(colunas *sizeof(int));
	} 
 	printf("Digite os valores da matriz: \n"); 
  	for(i =0; i < linhas; i++){
  		for(j =0; j < colunas; j++){
		 printf("Elemento [%d] [%d]: ", i,j);
		 	scanf("%d",&matriz[i][j]);
		}
	}
    printf("\n**************Matriz Digitada*************\n"); 
  	for(i = 0; i < linhas; i++){
  		for(j = 0; j < colunas; j++){
  	 		printf("%d ",*(*(matriz+i)+j));
 		}
 		printf("\n");
 	}
 	for ( i = 0; i < linhas; i++){
 		free(matriz[i]);
	 }
	free(matriz);
 	return 0;
 }
