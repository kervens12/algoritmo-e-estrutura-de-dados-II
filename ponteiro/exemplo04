 #include <stdio.h>
 #include <stdlib.h>
 
 int main(){ 
 	int n;
	int i;
	
	printf("Digite o tamanho do vetor: ");
		scanf("%d",&n);  
 	//alocacao dinamica
	int *p =(int*) malloc(n * sizeof(int));
	if (p == NULL){
		printf("Erro ao alocar memoria !!!\n");
	return 1;
	} 
	//leitura dos valores
	for(i = 0; i < n; i++){
 	 	printf("Digite o elemento %d: ",i);
 	 	scanf("%d",(p+i));
	}
	printf("\n=========Elementos do Vetor=========\n");
 	for(i = 0; i < n; i++){
 	 	printf("Elemento %d: %d\n",i,*(p+i));
	}
	free(p);
 	return 0;
 }
